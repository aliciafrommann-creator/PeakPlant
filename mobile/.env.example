# PeakPlant mobile — public client env vars.
#
# Backend mode is LIVE: copy this file to `.env` to run the app against the
# Supabase project locally. These are PUBLIC keys (publishable / anon) and are
# safe to ship in the client — the same values are wired into eas.json for
# preview/production builds. NEVER put the service_role / sb_secret key here.
#
# Leave these unset to run fully local-first on AsyncStorage seed data.

EXPO_PUBLIC_SUPABASE_URL=https://kmlqjmxkcnkfwsbptvuc.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_yXn6he-Mbcr5JQQoeBa1FQ_8l8WIqql

# The Anthropic key for Ask PeakPlant is NOT a client var. It lives only as a
# Supabase Edge Function secret (ANTHROPIC_API_KEY). The client never holds it.
